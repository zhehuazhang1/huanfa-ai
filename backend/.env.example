# Runtime mode.
# local/demo can keep mock providers. production must replace mock providers.
APP_ENV=local
CORS_ALLOW_ORIGINS=*

# Database.
# Local demo can use SQLite. Production should use MySQL.
HAIR_AI_DB_PATH=/data/hair_ai.sqlite3
DATABASE_URL=sqlite:////data/hair_ai.sqlite3
# Production example:
# DATABASE_URL=mysql+pymysql://hair_ai:change_this_password@mysql:3306/hair_ai
# MYSQL_INIT_SCHEMA=0
REDIS_URL=redis://redis:6379/0

# Dify self-hosted or cloud endpoint.
# Leave DIFY_BASE_URL and DIFY_API_KEY empty to use MockDifyClient.
# DIFY_BASE_URL=https://dify.yourdomain.com
DIFY_BASE_URL=
DIFY_API_KEY=
DIFY_TIMEOUT_SECONDS=60

# WeChat mini program login.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# WeChat Pay for paid AI trials.
# Service orders are still paid in store. AI trial paid uses must use WeChat Pay in commercial MVP.
PAYMENT_PROVIDER=mock
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_NOTIFY_URL=

# Tongyi Wanxiang / DashScope key is normally configured inside Dify.
# Keep a platform copy here only for direct-provider fallback or cost audit.
ALIYUN_DASHSCOPE_API_KEY=
ALIYUN_IMAGESEG_ENDPOINT=imageseg.cn-shanghai.aliyuncs.com
ALIYUN_WANX_TIMEOUT_SECONDS=180
ALIYUN_WAN27_REFERENCE_MODEL=wan2.7-image
AI_VARIANT_PARALLELISM=3

# Shared secret used only by Dify HTTP nodes when calling the internal AI adapter.
AI_ADAPTER_TOKEN=

# Temp selfie/result image storage.
# mock: local POC/demo only. aliyun_oss: generate short-lived signed OSS upload/read URLs.
# Configure an OSS lifecycle rule for temp/ objects as a cleanup fallback.
TEMP_STORAGE_PROVIDER=mock
OSS_BUCKET=
OSS_REGION=
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Feishu statistics sync.
FEISHU_SYNC_PROVIDER=mock
FEISHU_WEBHOOK_URL=

# AI 图片生成成本统计。
# 当 Dify/通义万相工作流没有回填真实成本时，后端按 "图片张数 × 此单价" 自算 internal_api_cost（元/张）。
# 需按真实通义万相计费校准；一次生成 3 张图时，每次成本 ≈ 3 × AI_IMAGE_UNIT_COST。
AI_IMAGE_UNIT_COST=0.15

# 平台向发廊的结算单价（元/组），即每次 AI 试发向商家收取的金额。
# BUG-01 修复：从 1.8 改为 2.0
PLATFORM_AI_SETTLE_PRICE=2.0

# 余额预警阈值（次数）
LOW_BALANCE_THRESHOLD=50
CRITICAL_BALANCE_THRESHOLD=20
