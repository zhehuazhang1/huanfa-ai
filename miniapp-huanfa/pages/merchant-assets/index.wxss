.direction-tabs {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.direction-tab {
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  background: #fff;
  color: #717976;
  font-size: 24rpx;
  border: 2rpx solid transparent;
}

.direction-tab.active {
  background: #01261f;
  color: #fff;
  font-weight: 800;
  border-color: #01261f;
  box-shadow: 0 10rpx 22rpx rgba(1, 38, 31, 0.18);
}

.asset-type-tabs {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 22rpx;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #eeeeec;
}

.asset-type-tab {
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border-radius: 999rpx;
  color: #717976;
  font-size: 26rpx;
  font-weight: 800;
  border: 2rpx solid transparent;
}

.asset-type-tab.active {
  background: #01261f;
  color: #fff;
  border-color: #01261f;
  box-shadow: 0 10rpx 22rpx rgba(1, 38, 31, 0.18);
}

.asset-count {
  min-width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.55);
  color: #01261f;
  font-size: 20rpx;
  text-align: center;
}

.asset-type-tab.active .asset-count {
  background: rgba(255, 255, 255, 0.18);
  color: #fff;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 30rpx;
  gap: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
}

.section-subtitle {
  margin-top: 6rpx;
  color: #717976;
  font-size: 22rpx;
}

.asset-card {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fff;
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.asset-main {
  flex: 1;
  min-width: 0;
}

.style-thumb {
  width: 138rpx;
  height: 172rpx;
  flex: none;
  border-radius: 18rpx;
  background: #f4f4f2;
}

.asset-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #1a1c1b;
  line-height: 1.25;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.asset-meta {
  margin-top: 8rpx;
  color: #717976;
  font-size: 23rpx;
}

.asset-desc {
  margin-top: 6rpx;
  color: #4d554b;
  font-size: 23rpx;
  line-height: 1.35;
}

.asset-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.5);
  color: #01261f;
  font-size: 22rpx;
}

.asset-side {
  flex: 0 0 96rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 14rpx;
}

.detail-hint {
  color: #717976;
  font-size: 22rpx;
  font-weight: 700;
}

.color-dot {
  width: 82rpx;
  height: 82rpx;
  flex: none;
  border-radius: 50%;
  border: 2rpx solid rgba(23, 26, 23, 0.1);
}

.color-thumb {
  width: 118rpx;
  height: 148rpx;
  flex: none;
  border-radius: 18rpx;
  background: #f4f4f2;
}

.color-asset-card {
  align-items: center;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.mini-tag {
  max-width: 180rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #f4f4f2;
  color: #414846;
  font-size: 21rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.small-button {
  height: 58rpx;
  min-width: 132rpx;
  margin: 0;
  padding: 0 24rpx;
  font-size: 24rpx;
  line-height: 1;
}

.empty {
  margin-top: 24rpx;
  color: #717976;
  text-align: center;
}
