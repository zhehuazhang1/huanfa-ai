.view-tabs {
  display: flex;
  margin-top: 24rpx;
  background: #fff;
  border-radius: 999rpx;
  padding: 6rpx;
  gap: 6rpx;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
}

.view-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  border-radius: 999rpx;
  font-size: 25rpx;
  font-weight: 700;
  color: #717976;
}

.view-tab.active {
  background: #01261f;
  color: #fff;
}

.date-range {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
}

.date-picker {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #1a1c1b;
}

.date-sep {
  color: #717976;
  font-size: 24rpx;
}

.status-tabs {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.status-tab {
  flex: 0 0 auto;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #72786f;
  font-size: 24rpx;
}

.status-tab.active {
  background: #01261f;
  color: #fff;
  font-weight: 800;
}

.empty {
  margin-top: 160rpx;
  text-align: center;
  color: #72786f;
}

.order-card {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.order-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.order-title {
  font-size: 28rpx;
  font-weight: 800;
}

.order-status {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.5);
  color: #01261f;
  font-size: 22rpx;
}

.order-line {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #4c544c;
  line-height: 1.4;
}

.talk-card {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 18rpx;
  background: #f4f4f2;
  color: #414846;
  font-size: 22rpx;
  line-height: 1.4;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.small-button {
  height: 60rpx;
  min-width: 118rpx;
  margin: 0;
  padding: 0 24rpx;
  font-size: 23rpx;
  line-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.small-button::after {
  border: none;
}

.settle-button {
  min-width: 176rpx;
}
