<view class="page chat-page">
  <view class="brand-row">
    <view>
      <view class="brand-name">咨询师</view>
      <view class="muted">可以咨询发型、发色、价格、护理和预约建议</view>
    </view>
  </view>

  <view class="quick-prompts">
    <view wx:for="{{quickPrompts}}" wx:key="*this" class="prompt-chip" data-text="{{item}}" bindtap="sendQuick">{{item}}</view>
  </view>

  <scroll-view class="message-list" scroll-y scroll-into-view="{{scrollInto}}">
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}" class="message {{item.role}}">
      <view class="bubble-wrap">
        <view class="bubble">{{item.text}}</view>
        <view wx:if="{{item.actions && item.actions.length}}" class="message-actions">
          <button wx:for="{{item.actions}}" wx:key="type" class="message-action" data-target="{{item.target}}" bindtap="handleAction">{{item.label}}</button>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="input-bar">
    <input class="chat-input" value="{{message}}" placeholder="咨询价格、预约、AI试发..." bindinput="onInput" confirm-type="send" bindconfirm="sendMessage" />
    <view class="send-button primary-button {{sending ? 'disabled' : ''}}" bindtap="sendMessage">{{sending ? '...' : '发送'}}</view>
  </view>

  <view class="bottom-nav chat-nav">
    <view class="nav-item" bindtap="goHome"><text class="nav-icon">首</text>首页</view>
    <view class="nav-item" bindtap="goStyle"><text class="nav-icon">试</text>AI试发</view>
    <view class="nav-item active" bindtap="goChat"><text class="nav-icon">咨</text>咨询师</view>
    <view class="nav-item" bindtap="goMe"><text class="nav-icon">我</text>我的</view>
  </view>
</view>
