.chat-page {
  padding-bottom: 270rpx;
}

.quick-prompts {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.prompt-chip {
  flex: 0 0 auto;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: #fff;
  color: #01261f;
  font-size: 23rpx;
  box-shadow: 0 8rpx 18rpx rgba(26, 60, 52, 0.05);
}

.message-list {
  height: calc(100vh - 390rpx);
  margin-top: 28rpx;
}

.message {
  display: flex;
  margin-bottom: 18rpx;
}

.message.user {
  justify-content: flex-end;
}

.message.assistant {
  justify-content: flex-start;
}

.bubble-wrap {
  max-width: 78%;
}

.message.user .bubble-wrap {
  display: flex;
  justify-content: flex-end;
}

.bubble {
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  font-size: 27rpx;
  line-height: 1.45;
  background: #fff;
  color: #1a1c1b;
  box-shadow: 0 8rpx 20rpx rgba(26, 60, 52, 0.05);
}

.message-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.message-action {
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: 999rpx;
  border: 2rpx solid rgba(1, 38, 31, 0.12);
  background: #eef6f2;
  color: #01261f;
  font-size: 24rpx;
  font-weight: 700;
}

.message-action::after {
  border: 0;
}

.message.user .bubble {
  background: #01261f;
  color: #fff;
}

.input-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 140rpx;
  display: grid;
  grid-template-columns: minmax(0, 1fr) 100rpx;
  gap: 10rpx;
  padding: 14rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 18rpx 44rpx rgba(26, 60, 52, 0.11);
  z-index: 30;
}

.chat-input {
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #f4f4f2;
  font-size: 26rpx;
}

.send-button {
  width: 100rpx;
  height: 76rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(1, 38, 31, 0.2);
  border-radius: 999rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.send-button.disabled {
  opacity: 0.72;
}

.chat-nav {
  bottom: 22rpx;
}
