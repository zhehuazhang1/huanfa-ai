.detail-page {
  padding-bottom: 48rpx;
}

.detail-hero {
  display: flex;
  gap: 20rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.hero-image,
.hero-color {
  width: 190rpx;
  height: 246rpx;
  flex: none;
  border-radius: 22rpx;
  background: #f4f4f2;
}

.hero-color {
  width: 150rpx;
  height: 150rpx;
  border: 2rpx solid rgba(23, 26, 23, 0.1);
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.type-pill {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.55);
  color: #01261f;
  font-size: 22rpx;
  font-weight: 800;
}

.detail-title {
  margin-top: 14rpx;
  color: #1a1c1b;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1.25;
}

.detail-card,
.danger-card {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.detail-row,
.danger-card {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 18rpx;
}

.detail-row {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eeeeec;
}

.detail-main {
  flex: 1;
  min-width: 0;
}

.detail-row.editing {
  display: block;
}

.detail-row:last-child {
  border-bottom: 0;
}

.row-title {
  color: #1a1c1b;
  font-size: 27rpx;
  font-weight: 800;
}

.row-value {
  margin-top: 8rpx;
  color: #717976;
  font-size: 24rpx;
  line-height: 1.45;
}

.preline {
  white-space: pre-line;
}

.row-button {
  flex: 0 0 auto;
  width: 132rpx;
  height: 62rpx;
  margin: 0 0 0 auto;
  font-size: 23rpx;
  align-self: flex-start;
  text-align: center;
  padding-left: 0;
  padding-right: 0;
}

.inline-input,
.inline-textarea {
  width: 100%;
  margin-top: 12rpx;
  padding: 16rpx 18rpx;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #f4f4f2;
  color: #1a1c1b;
  font-size: 25rpx;
  line-height: 1.45;
}

.inline-input {
  min-height: 72rpx;
}

.inline-textarea {
  min-height: 132rpx;
}

.param-textarea {
  min-height: 260rpx;
}

.inline-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 14rpx;
}

.inline-actions .row-button {
  margin-left: 0;
  width: 100%;
}

.delete-button {
  flex: 0 0 auto;
  width: 132rpx;
  height: 62rpx;
  margin: 0 0 0 auto;
  border-radius: 999rpx;
  background: #8e453d;
  color: #fff;
  font-size: 23rpx;
  align-self: flex-start;
  padding-left: 0;
  padding-right: 0;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.mini-tag {
  max-width: 180rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: #f4f4f2;
  color: #414846;
  font-size: 21rpx;
  line-height: 1.2;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
