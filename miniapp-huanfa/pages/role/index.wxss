.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 64rpx 32rpx 48rpx;
  background: #f9f9f7;
  color: #032f27;
}

.hero {
  padding: 24rpx 0 48rpx;
}

.brand-mark {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #003b31;
  color: #ffffff;
  font-weight: 800;
  font-size: 34rpx;
  margin-bottom: 24rpx;
}

.title {
  font-size: 56rpx;
  line-height: 1.15;
  font-weight: 800;
}

.subtitle {
  margin-top: 16rpx;
  color: #7a837f;
  font-size: 28rpx;
  line-height: 1.6;
}

.mode-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.mode-card {
  min-height: 176rpx;
  border-radius: 18rpx;
  padding: 30rpx;
  box-sizing: border-box;
  background: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(2, 43, 35, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.mode-card.merchant {
  background: #003b31;
  color: #ffffff;
}

.mode-title {
  font-size: 34rpx;
  font-weight: 800;
}

.mode-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7a837f;
}

.merchant .mode-desc {
  color: rgba(255, 255, 255, 0.72);
}

.mode-action {
  flex: 0 0 auto;
  min-width: 96rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #e7f5f0;
  color: #003b31;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.merchant .mode-action {
  background: #ffffff;
}

.tip {
  margin-top: 44rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #edf4f1;
  color: #5f6b67;
  font-size: 24rpx;
  line-height: 1.6;
}
