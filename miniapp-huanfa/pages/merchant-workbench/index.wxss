.workbench-hero {
  padding: 26rpx;
  border-radius: 28rpx;
  background: #01261f;
  color: #fff;
}

.workbench-hero .header-title,
.workbench-hero .muted {
  color: #fff;
}

.workbench-hero .muted {
  opacity: 0.78;
}

.role-pill {
  display: inline-flex;
  margin-bottom: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.16);
  color: #c5eadf;
  font-size: 22rpx;
  font-weight: 800;
}

.merchant-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 28rpx;
}

.revenue-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.revenue-label {
  color: #1a1c1b;
  font-size: 28rpx;
  font-weight: 800;
}

.revenue-desc {
  margin-top: 6rpx;
  color: #717976;
  font-size: 22rpx;
  line-height: 1.35;
}

.revenue-value {
  flex: 0 0 auto;
  color: #01261f;
  font-size: 36rpx;
  font-weight: 900;
}

.merchant-tile {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.tile-icon {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #f4f4f2;
  color: #01261f;
  font-size: 24rpx;
  font-weight: 800;
}

.manage-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1c1b;
}

.manage-desc {
  margin-top: 8rpx;
  color: #717976;
  font-size: 24rpx;
}

.today-panel {
  margin-top: 30rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1c1b;
}

.appointment-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #eeeeec;
}

.appointment-name {
  color: #1a1c1b;
  font-size: 26rpx;
  font-weight: 800;
}

.appointment-status {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.5);
  color: #01261f;
  font-size: 22rpx;
  font-weight: 800;
}

.muted-status {
  color: #717976;
  background: #f4f4f2;
}
