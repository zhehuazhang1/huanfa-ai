.result-page {
  padding-bottom: 144rpx;
}

.generating-screen {
  min-height: calc(100vh - 170rpx);
  display: flex;
  align-items: center;
  flex-direction: column;
  padding: 92rpx 0 130rpx;
  box-sizing: border-box;
}

.generating-ring {
  width: 232rpx;
  height: 232rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 6rpx solid #01261f;
  border-top-color: #dcebe5;
  border-radius: 50%;
  animation: spin 1.1s linear infinite;
  box-shadow: 0 26rpx 70rpx rgba(1, 38, 31, 0.08);
}

.generating-core {
  width: 116rpx;
  height: 116rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #fff;
  color: #01261f;
  font-size: 28rpx;
  animation: counterSpin 1.1s linear infinite;
}

.generating-title {
  margin-top: 74rpx;
  color: #01261f;
  font-size: 36rpx;
  font-weight: 900;
  text-align: center;
}

.generating-desc {
  max-width: 560rpx;
  margin-top: 24rpx;
  color: #414846;
  font-size: 28rpx;
  line-height: 1.55;
  text-align: center;
}

.generating-steps {
  width: 100%;
  margin-top: 88rpx;
}

.generating-step {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 14rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.5);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.05);
}

.step-icon {
  flex: 0 0 auto;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(1, 38, 31, 0.82);
  color: #fff;
  font-size: 22rpx;
  font-weight: 900;
}

.step-copy {
  min-width: 0;
}

.step-title {
  color: #1a1c1b;
  font-size: 30rpx;
  font-weight: 800;
}

.step-desc {
  margin-top: 8rpx;
  color: #717976;
  font-size: 22rpx;
  line-height: 1.35;
}

.generating-hint {
  margin-top: auto;
  padding-top: 70rpx;
  color: #8a918e;
  font-size: 22rpx;
}

.generation-state {
  display: flex;
  min-height: 620rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 20rpx;
}

.generation-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 8rpx solid #d8e8e1;
  border-top-color: #01261f;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.generation-title {
  color: #01261f;
  font-size: 30rpx;
  font-weight: 800;
}

.generation-refund-hint {
  color: #01261f;
  font-size: 26rpx;
  font-weight: 700;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes counterSpin {
  to { transform: rotate(-360deg); }
}

.result-swiper {
  width: 100%;
  height: 1010rpx;
  margin-top: 28rpx;
  background: transparent;
}

.result-card {
  height: 100%;
  margin: 0 4rpx;
  overflow: hidden;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 10rpx 28rpx rgba(26, 60, 52, 0.08);
}

.image-wrap {
  position: relative;
  width: 100%;
  height: 780rpx;
  background: #f4f4f2;
}

.result-image {
  width: 100%;
  height: 100%;
}

.plan-badge {
  position: absolute;
  left: 22rpx;
  top: 22rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #01261f;
  color: #fff;
  font-size: 23rpx;
  font-weight: 800;
}

.plan-badge.natural {
  background: #775a19;
}

.plan-badge.advanced {
  background: #717976;
}

.logo-watermark {
  position: absolute;
  right: 22rpx;
  bottom: 22rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  color: #01261f;
  font-size: 22rpx;
  font-weight: 800;
}

.result-meta {
  padding: 20rpx 22rpx;
}

.meta-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 12rpx;
}

.meta-label {
  flex: 0 0 auto;
  color: #01261f;
  font-size: 23rpx;
  font-weight: 800;
}

.meta-value {
  flex: 1;
  color: #1a1c1b;
  font-size: 24rpx;
  line-height: 1.35;
  text-align: right;
}

.dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin: 20rpx 0;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #c1c8c4;
}

.dot.active {
  width: 36rpx;
  background: #01261f;
}

.recommendation-loading {
  margin: 18rpx 0;
  color: #01261f;
  font-size: 24rpx;
  text-align: center;
}

.info-panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.panel-title {
  font-size: 30rpx;
  font-weight: 800;
}

.plan-desc {
  margin-top: 10rpx;
  color: #414846;
  font-size: 24rpx;
  line-height: 1.45;
}

.talk-point {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f4f4f2;
  color: #414846;
  font-size: 23rpx;
  line-height: 1.45;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.result-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.5);
  color: #01261f;
  font-size: 23rpx;
}

.stylist-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e2e3e1;
}

.stylist-row.selected {
  border-color: #01261f;
  background: #f4f4f2;
}

.stylist-avatar {
  width: 86rpx;
  height: 86rpx;
  border-radius: 999rpx;
  background: #e2e3e1;
}

.stylist-main {
  flex: 1;
  min-width: 0;
}

.stylist-name {
  font-size: 27rpx;
  font-weight: 800;
}

.default-mark {
  margin-left: 8rpx;
  color: #775a19;
  font-size: 21rpx;
}

.stylist-reason {
  margin-top: 6rpx;
  color: #717976;
  font-size: 22rpx;
  line-height: 1.35;
}

.order-button {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 24rpx;
  width: auto;
  min-width: 0;
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 800;
}
