<view class="page orders-page">
  <view class="brand-row">
    <view>
      <view class="brand-name">我的预约</view>
      <view class="muted">查看预约状态，到店后与主理人沟通确认</view>
    </view>
  </view>

  <button class="new-booking-button primary-button" bindtap="goBooking">立即预约</button>

  <view class="status-tabs">
    <view wx:for="{{statuses}}" wx:key="value" class="status-tab {{status === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="changeStatus">
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{orders.length === 0}}" class="empty">
    <view class="empty-title">还没有预约记录</view>
    <view class="empty-desc">先试一张灵感造型，再预约主理人沟通。</view>
    <button class="empty-button primary-button" bindtap="goBooking">立即预约</button>
  </view>

  <view wx:for="{{orders}}" wx:key="id" class="order-card">
    <view class="order-top">
      <view>
        <view class="order-store">{{item.store_name || '门店'}}</view>
        <view class="order-source">{{item.sourceText}}</view>
      </view>
      <view class="order-status">{{statusText[item.status] || item.status}}</view>
    </view>
    <view class="order-line">主理人：{{item.stylist_name || '到店分配'}}</view>
    <view class="order-line">预约时间：{{item.appointmentText}}</view>
    <view class="order-line">方向：{{directionText[item.direction] || item.direction || '未填'}}</view>
    <view class="order-line">发型：{{item.hairstyleText}} / 发色：{{item.hairColorText}}</view>
    <view class="order-line muted">订单号：{{item.id}}</view>
    <view class="order-actions">
      <view class="order-action detail-button" data-id="{{item.id}}" bindtap="showOrderDetail">查看详情</view>
      <view class="order-action contact-button" data-id="{{item.id}}" bindtap="contactStore">联系门店</view>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goHome"><text class="nav-icon">首</text>首页</view>
    <view class="nav-item" bindtap="goStyle"><text class="nav-icon">试</text>AI试发</view>
    <view class="nav-item" bindtap="goChat"><text class="nav-icon">咨</text>咨询师</view>
    <view class="nav-item active" bindtap="goMe"><text class="nav-icon">我</text>我的</view>
  </view>
</view>
