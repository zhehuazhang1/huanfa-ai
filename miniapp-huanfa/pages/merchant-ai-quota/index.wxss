.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 22rpx 160rpx;
  background: #f6f7f4;
  color: #062d25;
}

.header-title {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.2;
}

.muted,
.form-desc,
.picker-desc,
.record-desc,
.record-line,
.empty-line {
  color: #7a827d;
  font-size: 24rpx;
  line-height: 1.55;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 22rpx;
}

.metric-card,
.form-card,
.record-card {
  background: #fff;
  border: 1rpx solid rgba(6, 45, 37, 0.08);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 42, 35, 0.07);
}

.metric-card {
  min-height: 128rpx;
  box-sizing: border-box;
  padding: 24rpx;
}

.metric-value {
  font-size: 36rpx;
  font-weight: 900;
}

.metric-label {
  margin-top: 8rpx;
  color: #6f7772;
  font-size: 23rpx;
}

.form-card {
  margin-top: 22rpx;
  padding: 24rpx;
}

.form-title,
.section-title {
  font-size: 30rpx;
  font-weight: 900;
}

.form-desc {
  margin-top: 8rpx;
}

.picker-field,
.input-row,
.record-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.picker-field {
  min-height: 96rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  border-radius: 14rpx;
  background: #f2f4f0;
}

.picker-name {
  font-size: 28rpx;
  font-weight: 800;
}

.picker-arrow {
  flex: 0 0 auto;
  color: #00624f;
  font-size: 24rpx;
  font-weight: 800;
}

.input-row {
  height: 90rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  border-radius: 14rpx;
  background: #f2f4f0;
  font-size: 26rpx;
  font-weight: 800;
}

.number-input {
  width: 160rpx;
  height: 70rpx;
  text-align: right;
  font-size: 30rpx;
  font-weight: 900;
}

.submit-button,
.quota-button {
  width: 100%;
  height: 86rpx;
  margin-top: 20rpx;
  border-radius: 43rpx;
  font-size: 28rpx;
  font-weight: 900;
}

.section-title {
  margin-top: 30rpx;
}

.empty-line {
  margin-top: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  background: #fff;
}

.record-card {
  margin-top: 16rpx;
  padding: 22rpx;
}

.record-title {
  font-size: 28rpx;
  font-weight: 900;
}

.record-line {
  margin-top: 8rpx;
}

.status-pill {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e6f5ef;
  color: #00624f;
  font-size: 22rpx;
  font-weight: 800;
}

.status-pill.used {
  background: #f1eadf;
  color: #7a572b;
}
