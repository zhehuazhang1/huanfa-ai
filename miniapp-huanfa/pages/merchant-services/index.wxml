<view class="page">
  <view class="header-title">服务项目</view>
  <view class="muted">商家可按业务增加、停用或重新启用剪发、染发、烫发、造型、护理</view>

  <view class="status-tabs">
    <view wx:for="{{statusTabs}}" wx:key="value" class="status-tab {{filterStatus === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="changeStatus">{{item.label}}</view>
  </view>

  <view class="add-panel">
    <picker mode="selector" range="{{categoryOptions}}" range-key="label" value="{{categoryIndex}}" bindchange="changeCategory">
      <view class="picker-button">新增分类：{{currentCategoryLabel}}</view>
    </picker>
    <button class="primary-button add-button" bindtap="addService">新增服务项目</button>
  </view>

  <view wx:if="{{filteredServices.length === 0}}" class="empty">暂无服务项目</view>

  <view wx:for="{{filteredServices}}" wx:key="id" class="service-card {{item.is_enabled ? '' : 'disabled'}}">
    <view class="service-main">
      <view class="service-name">{{item.displayName}}</view>
      <view class="service-meta">{{item.categoryLabel}} / ¥{{item.base_price}} / {{item.statusLabel}}</view>
    </view>
    <view class="service-actions">
      <view class="action-link" data-id="{{item.id}}" bindtap="editService">编辑</view>
      <button class="small-button {{item.is_enabled ? 'secondary-button' : 'primary-button'}}" data-id="{{item.id}}" data-enabled="{{item.is_enabled}}" bindtap="toggleService">{{item.is_enabled ? '停用' : '启用'}}</button>
    </view>
  </view>

  <view wx:if="{{dialogVisible}}" class="dialog-mask" catchtap="closeDialog">
    <view class="service-dialog" catchtap="noop">
      <view class="dialog-title">{{dialogMode === 'edit' ? '编辑服务项目' : '新增服务项目'}}</view>
      <view class="dialog-subtitle">名称、分类和价格会用于补录服务与数据看板</view>
      <view class="dialog-field">
        <view class="dialog-label">服务分类</view>
        <picker mode="selector" range="{{categoryOptions}}" range-key="label" value="{{categoryIndex}}" bindchange="changeCategory">
          <view class="dialog-picker">{{currentCategoryLabel}}</view>
        </picker>
      </view>
      <view class="dialog-field">
        <view class="dialog-label">服务名称</view>
        <input class="dialog-input" value="{{dialogForm.name}}" bindinput="inputDialogName" placeholder="例如：高级染发" />
      </view>
      <view class="dialog-field">
        <view class="dialog-label">基础价格</view>
        <input class="dialog-input" type="digit" value="{{dialogForm.price}}" bindinput="inputDialogPrice" placeholder="例如：399" />
      </view>
      <view class="dialog-actions">
        <view class="dialog-button secondary" bindtap="closeDialog">取消</view>
        <view class="dialog-button primary" bindtap="saveServiceDialog">{{dialogSubmitting ? '保存中' : '保存'}}</view>
      </view>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goWorkbench"><text class="nav-icon">台</text>工作台</view>
    <view class="nav-item" bindtap="goOrders"><text class="nav-icon">单</text>订单</view>
    <view class="nav-item active"><text class="nav-icon">素</text>素材</view>
    <view class="nav-item" bindtap="goCustomers"><text class="nav-icon">客</text>顾客</view>
    <view class="nav-item" bindtap="goPerformance"><text class="nav-icon">数</text>数据</view>
  </view>
</view>
