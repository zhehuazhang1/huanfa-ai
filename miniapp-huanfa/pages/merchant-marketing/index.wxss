.form-card,
.package-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.form-title,
.section-title {
  color: #01261f;
  font-size: 30rpx;
  font-weight: 900;
}

.small-muted {
  margin-top: 8rpx;
  font-size: 23rpx;
}

.section-title {
  margin-top: 34rpx;
}

.field {
  margin-top: 20rpx;
}

.field-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
}

.field-label {
  color: #1a1c1b;
  font-size: 24rpx;
  font-weight: 800;
}

.field-input,
.picker-value {
  box-sizing: border-box;
  width: 100%;
  min-height: 76rpx;
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f7f7f5;
  color: #1a1c1b;
  font-size: 25rpx;
  line-height: 1.35;
}

.add-button {
  height: 84rpx;
  margin-top: 26rpx;
  font-size: 28rpx;
}

.settle-actions {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 18rpx;
  margin-top: 24rpx;
}

.settle-action {
  box-sizing: border-box;
  min-width: 0;
  width: 100%;
  height: 78rpx;
  margin: 0;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  white-space: nowrap;
}

.settle-action::after {
  border: none;
}

.empty {
  margin-top: 16rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fff;
  color: #717976;
  font-size: 24rpx;
}

.package-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.package-card.disabled {
  opacity: 0.62;
}

.package-main {
  flex: 1;
  min-width: 0;
}

.package-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.package-name {
  min-width: 0;
  color: #1a1c1b;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-pill {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.55);
  color: #01261f;
  font-size: 22rpx;
  font-weight: 800;
}

.package-price {
  margin-top: 12rpx;
  color: #01261f;
  font-size: 34rpx;
  font-weight: 900;
}

.package-price text,
.package-meta {
  color: #717976;
  font-size: 23rpx;
  font-weight: 500;
}

.package-meta {
  margin-top: 8rpx;
  line-height: 1.45;
}

.small-button {
  flex: 0 0 auto;
  width: 128rpx;
  height: 64rpx;
  padding: 0;
  font-size: 24rpx;
}
