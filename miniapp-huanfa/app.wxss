page {
  min-height: 100vh;
  background: #f9f9f7;
  color: #1a1c1b;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  border-radius: 999rpx;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx calc(220rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.brand-name {
  font-size: 42rpx;
  font-weight: 800;
  letter-spacing: 0;
  color: #01261f;
  line-height: 1.18;
}

.muted {
  color: #717976;
  font-size: 25rpx;
  line-height: 1.45;
}

.primary-button {
  background: #01261f;
  color: #fff;
  border: 0;
  box-shadow: 0 16rpx 34rpx rgba(26, 60, 52, 0.18);
}

.secondary-button {
  background: #ffffff;
  color: #01261f;
  border: 0;
  box-shadow: 0 8rpx 22rpx rgba(26, 60, 52, 0.06);
}

.danger-button {
  background: #8e453d;
  color: #fff;
  border: 0;
}

.bottom-nav {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 22rpx;
  min-height: 110rpx;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(96rpx, 1fr));
  align-items: center;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(113, 121, 118, 0.16);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 44rpx rgba(26, 60, 52, 0.11);
  z-index: 20;
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-item {
  text-align: center;
  font-size: 23rpx;
  color: #717976;
  line-height: 1.2;
}

.nav-item.active {
  color: #01261f;
  font-weight: 800;
}

.nav-icon {
  display: block;
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  margin: 0 auto 6rpx;
  border-radius: 16rpx;
  background: #f4f4f2;
  color: #01261f;
  font-size: 24rpx;
  font-weight: 800;
}

.nav-item.active .nav-icon {
  color: #ffffff;
  background: #01261f;
}

.surface-card {
  background: #ffffff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.soft-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.5);
  color: #01261f;
  font-size: 22rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #01261f;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  margin-top: 26rpx;
}

.metric-card {
  min-height: 124rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
  box-sizing: border-box;
}

.metric-value {
  font-size: 38rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #01261f;
}

.metric-label {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.35;
  color: #72786f;
}
