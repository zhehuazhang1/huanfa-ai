.member-page {
  padding-bottom: 174rpx;
}

.member-card,
.package-card,
.tx-card,
.empty-card {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.member-top,
.balance-row,
.package-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.member-label,
.balance-label,
.package-meta,
.tx-meta,
.empty-desc {
  color: #717976;
  font-size: 24rpx;
  line-height: 1.45;
}

.member-level {
  margin-top: 8rpx;
  color: #1a1c1b;
  font-size: 34rpx;
  font-weight: 900;
}

.package-status {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.55);
  color: #01261f;
  font-size: 23rpx;
  font-weight: 900;
}

.balance-label {
  margin-top: 26rpx;
}

.balance-value {
  margin-top: 8rpx;
  color: #01261f;
  font-size: 58rpx;
  font-weight: 900;
}

.balance-row {
  justify-content: flex-start;
  flex-wrap: wrap;
  margin-top: 12rpx;
  color: #717976;
  font-size: 23rpx;
}

.member-tip {
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f5f0e0;
  color: #7a5a00;
  font-size: 24rpx;
  line-height: 1.45;
}

.section-title {
  margin-top: 34rpx;
  color: #01261f;
  font-size: 32rpx;
  font-weight: 900;
}

.empty-card.small {
  padding: 22rpx;
}

.empty-title,
.package-name,
.tx-title {
  min-width: 0;
  color: #1a1c1b;
  font-size: 28rpx;
  font-weight: 900;
}

.package-line {
  margin-top: 14rpx;
  color: #414846;
  font-size: 25rpx;
  line-height: 1.5;
}

.package-meta,
.tx-meta {
  margin-top: 10rpx;
}
