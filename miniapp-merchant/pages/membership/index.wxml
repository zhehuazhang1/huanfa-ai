<view class="page">
  <view class="header-title">会员套餐</view>
  <view class="muted">查看当前版本、AI 次数和门店权益，升级由平台统一处理</view>

  <view wx:if="{{loading}}" class="state-card">正在加载套餐信息...</view>

  <view wx:else>
    <view class="plan-hero">
      <view>
        <view class="plan-eyebrow">当前套餐</view>
        <view class="plan-name">{{currentPlan.display_name || '免费试用'}}</view>
        <view class="plan-desc">
          {{currentPlan.annualPriceText === '0' ? '试用阶段' : '¥' + currentPlan.annualPriceText + ' / 年'}}
          · 赠送 {{currentPlan.annual_included_ai_quota || 0}} 次 AI 试发
        </view>
      </view>
      <view class="plan-status">{{subscription.subscription_expires_at ? '有效期内' : '试用中'}}</view>
    </view>

    <view class="metric-grid">
      <view class="metric-card">
        <view class="metric-value">{{subscription.remainingText}}</view>
        <view class="metric-label">本期剩余次数</view>
      </view>
      <view class="metric-card">
        <view class="metric-value">{{subscription.usedText}}</view>
        <view class="metric-label">本期已用次数</view>
      </view>
      <view class="metric-card">
        <view class="metric-value">{{subscription.quotaText}}</view>
        <view class="metric-label">本期总额度</view>
      </view>
      <view class="metric-card">
        <view class="metric-value">{{currentPlan.storeLimitText}}</view>
        <view class="metric-label">门店额度</view>
      </view>
    </view>

    <view class="info-card">
      <view class="section-title">套餐权益</view>
      <view class="feature-row" wx:for="{{featureRows}}" wx:key="key">
        <view>{{item.label}}</view>
        <view class="feature-badge {{item.enabled ? 'enabled' : ''}}">
          {{item.enabled ? '已开通' : '未开通'}}
        </view>
      </view>
    </view>

    <view class="info-card">
      <view class="section-title">可选套餐</view>
      <view class="plan-row {{item.active ? 'active' : ''}}" wx:for="{{plans}}" wx:key="plan">
        <view>
          <view class="row-title">{{item.display_name}}</view>
          <view class="row-desc">¥{{item.annualPriceText}} / 年 · 赠送 {{item.annual_included_ai_quota}} 次 · {{item.storeLimitText}}</view>
        </view>
        <view class="row-pill">{{item.active ? '当前' : '可升级'}}</view>
      </view>
    </view>

    <view class="info-card">
      <view class="section-title">最近账单</view>
      <view wx:if="{{!bills.length}}" class="empty-text">暂无账单记录</view>
      <view class="bill-row" wx:for="{{bills}}" wx:key="id">
        <view>
          <view class="row-title">{{item.bill_month || '账单'}}</view>
          <view class="row-desc">{{item.status || 'pending'}}</view>
        </view>
        <view class="bill-amount">¥{{item.total_bill_amount || 0}}</view>
      </view>
    </view>

    <view class="action-grid">
      <button class="primary-button action-button" bindtap="contactPlatform">联系平台升级</button>
      <button class="secondary-button action-button" bindtap="goQuota">查看 AI 次数</button>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goWorkbench"><text class="nav-icon">台</text>工作台</view>
    <view class="nav-item" bindtap="goOrders"><text class="nav-icon">单</text>订单</view>
    <view class="nav-item" bindtap="goAssets"><text class="nav-icon">素</text>素材</view>
    <view class="nav-item" bindtap="goCustomers"><text class="nav-icon">客</text>顾客</view>
    <view class="nav-item" bindtap="goPerformance"><text class="nav-icon">数</text>数据</view>
  </view>
</view>
