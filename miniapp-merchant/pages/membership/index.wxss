.state-card,
.info-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.state-card {
  color: #717976;
  font-size: 26rpx;
  text-align: center;
}

.plan-hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #01261f;
  color: #fff;
}

.plan-eyebrow {
  display: inline-flex;
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.16);
  color: #c5eadf;
  font-size: 22rpx;
  font-weight: 800;
}

.plan-name {
  margin-top: 18rpx;
  font-size: 42rpx;
  font-weight: 900;
}

.plan-desc {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.45;
}

.plan-status,
.row-pill,
.feature-badge {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.plan-status {
  background: rgba(255, 255, 255, 0.13);
  color: #c5eadf;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1c1b;
}

.feature-row,
.plan-row,
.bill-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #eeeeec;
  color: #1a1c1b;
  font-size: 26rpx;
}

.feature-row:first-of-type,
.plan-row:first-of-type,
.bill-row:first-of-type {
  margin-top: 14rpx;
}

.feature-badge {
  background: #f4f4f2;
  color: #717976;
}

.feature-badge.enabled,
.row-pill {
  background: rgba(197, 234, 223, 0.55);
  color: #01261f;
}

.plan-row.active {
  padding-left: 18rpx;
  padding-right: 18rpx;
  border-radius: 18rpx;
  background: #f4fbf7;
}

.row-title {
  color: #1a1c1b;
  font-size: 28rpx;
  font-weight: 800;
}

.row-desc {
  margin-top: 7rpx;
  color: #717976;
  font-size: 23rpx;
  line-height: 1.4;
}

.bill-amount {
  flex: 0 0 auto;
  color: #01261f;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-text {
  margin-top: 18rpx;
  color: #717976;
  font-size: 24rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 24rpx;
}

.action-button {
  height: 88rpx;
  font-size: 28rpx;
  font-weight: 800;
}
