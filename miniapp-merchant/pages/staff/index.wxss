.add-button {
  height: 82rpx;
  margin-top: 26rpx;
  font-size: 28rpx;
}

.staff-card {
  margin-top: 18rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.staff-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: #01261f;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 72rpx;
  text-align: center;
  flex-shrink: 0;
}

.staff-main {
  min-width: 0;
  flex: 1;
}

.staff-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.staff-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #1a1c1b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.staff-title {
  margin-top: 4rpx;
  color: #717976;
  font-size: 24rpx;
}

.staff-summary {
  margin-top: 8rpx;
  color: #46504c;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-pill {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.5);
  color: #01261f;
  font-size: 22rpx;
  line-height: 1.2;
  flex-shrink: 0;
}

.status-busy {
  background: #fff4d7;
  color: #85610a;
}

.status-off_duty {
  background: #f1f1ef;
  color: #717976;
}

.status-switch {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 6rpx;
  margin-top: 18rpx;
  padding: 6rpx;
  border-radius: 16rpx;
  background: #f4f4f2;
  overflow: hidden;
}

.status-button {
  width: 100%;
  min-width: 0;
  height: 54rpx;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  background: transparent;
  color: #46504c;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 54rpx;
  text-align: center;
}

.status-button.active {
  background: #01261f;
  color: #fff;
}

.empty {
  margin-top: 120rpx;
  color: #717976;
  text-align: center;
}
