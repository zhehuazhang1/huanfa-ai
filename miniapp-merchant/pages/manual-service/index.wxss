.form-card {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.field {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eceeea;
}

.field:last-child {
  border-bottom: 0;
}

.field-label {
  color: #1a1c1b;
  font-size: 26rpx;
  font-weight: 800;
}

.picker-value,
.field-input,
.field-textarea {
  box-sizing: border-box;
  width: 100%;
  margin-top: 12rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f7f7f5;
  color: #1a1c1b;
  font-size: 26rpx;
}

.field-input {
  height: 76rpx;
}

.field-textarea {
  min-height: 150rpx;
  line-height: 1.55;
}

.submit-button {
  height: 86rpx;
  margin-top: 28rpx;
  font-size: 28rpx;
}

.lookup-button {
  height: 68rpx;
  margin-top: 14rpx;
  font-size: 24rpx;
  border: 1rpx solid rgba(1, 38, 31, 0.12);
}
