.settings-page {
  padding-bottom: 164rpx;
}

.settings-card,
.photo-card,
.notice-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.field-label {
  margin-top: 22rpx;
  color: #1a1c1b;
  font-size: 25rpx;
  font-weight: 900;
}

.settings-card .field-label:first-child,
.photo-card .field-label:first-of-type {
  margin-top: 0;
}

.field-input,
.field-textarea {
  width: 100%;
  box-sizing: border-box;
  margin-top: 12rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #f4f4f2;
  color: #1a1c1b;
  font-size: 26rpx;
}

.field-input {
  height: 78rpx;
}

.field-textarea {
  min-height: 120rpx;
  padding-top: 18rpx;
  line-height: 1.45;
}

.section-title {
  margin-top: 34rpx;
  color: #1a1c1b;
  font-size: 31rpx;
  font-weight: 900;
}

.photo-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.photo-index {
  color: #01261f;
  font-size: 28rpx;
  font-weight: 900;
}

.notice-card {
  background: #eef6f2;
}

.notice-title {
  color: #01261f;
  font-size: 27rpx;
  font-weight: 900;
}

.notice-text {
  margin-top: 8rpx;
  color: #59615e;
  font-size: 24rpx;
  line-height: 1.45;
}

.settings-entry {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.entry-title {
  color: #01261f;
  font-size: 29rpx;
  font-weight: 900;
}

.entry-desc {
  margin-top: 8rpx;
  color: #717976;
  font-size: 24rpx;
  line-height: 1.4;
}

.entry-arrow {
  flex: 0 0 auto;
  color: #01261f;
  font-size: 46rpx;
  line-height: 1;
}

.save-button {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  font-size: 29rpx;
  font-weight: 900;
}
