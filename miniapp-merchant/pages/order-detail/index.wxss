.order-detail-page {
  padding-bottom: 48rpx;
}

.header-card,
.section-card {
  margin-top: 22rpx;
  padding: 26rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 1rpx solid rgba(193, 200, 196, 0.45);
  box-shadow: 0 8rpx 24rpx rgba(26, 60, 52, 0.06);
}

.header-card {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.order-title {
  color: #01261f;
  font-size: 36rpx;
  font-weight: 900;
}

.order-sub {
  margin-top: 8rpx;
  color: #717976;
  font-size: 24rpx;
}

.status-pill {
  flex: 0 0 auto;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(197, 234, 223, 0.55);
  color: #01261f;
  font-size: 23rpx;
  font-weight: 900;
}

.section-title {
  color: #1a1c1b;
  font-size: 30rpx;
  font-weight: 900;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding-top: 22rpx;
}

.detail-label {
  flex: 0 0 auto;
  color: #717976;
  font-size: 25rpx;
}

.detail-value {
  min-width: 0;
  color: #1a1c1b;
  font-size: 27rpx;
  line-height: 1.45;
  text-align: right;
}

.detail-value.strong {
  color: #01261f;
  font-weight: 900;
}

.notes-box {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 18rpx;
  background: #f4f4f2;
  color: #414846;
  font-size: 26rpx;
  line-height: 1.55;
}

.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-button {
  width: 100%;
  height: 82rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
  line-height: 82rpx;
}

.action-button.primary {
  background: #01261f;
  color: #fff;
}

.action-button.secondary {
  background: #eef3ef;
  color: #01261f;
}
